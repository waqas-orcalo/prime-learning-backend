# ─── Application ─────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── MongoDB ─────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/prime-backend

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d

# ─── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins. Use '*' for open dev.
CORS_ORIGINS=http://localhost:3001
