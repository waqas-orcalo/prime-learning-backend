# ─────────────────────────────────────────────────────────────────────────────
# Prime Learning Backend — Environment Variables
# Copy this file to .env and fill in the values before running.
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ── MongoDB ───────────────────────────────────────────────────────────────────
# When running via docker-compose the URI is built automatically.
# For standalone / managed Atlas deployments set it here:
mongodb://admin:password@localhost:27017

# docker-compose Mongo root credentials (used to build MONGO_URI inside compose)
MONGO_ROOT_USER=admin
MONGO_ROOT_PASS=adminpass

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string-in-production
JWT_EXPIRES_IN=7d

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins, or '*' for development.
CORS_ORIGINS=http://localhost:3001,https://your-frontend-domain.com

# ── Host port for the API container (docker-compose only) ─────────────────────
API_PORT=3000
